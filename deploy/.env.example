# ============================================================
# PertenSer — Variáveis de produção (VPS)
# Copie para .env e preencha os valores antes do deploy:
#   cp .env.example .env && nano .env
# ============================================================

# Domínio público (usado no CORS do backend e nos certificados)
DOMAIN=www.pertenser.com.br
DOMAIN_ALT=pertenser.com.br
FRONTEND_URL=https://www.marcelokevin.com.br

# E-mail para Let's Encrypt (avisos de expiração)
# CERTBOT_EMAIL=admin@pertenser.com.br

# PostgreSQL
POSTGRES_PASSWORD=Kevin123

# JWT — gere com: openssl rand -hex 64
JWT_SECRET="1c2808e6b2d1af2e34dd99f14f2434a15f9672fd6398ca94ae73a6d3cadb4900d9c0f2c6b8cbdc18d5452446b455f30d73157453452d410a2a59d1ce667b8ad4"
JWT_EXPIRES_IN=7d

# Upload
MAX_FILE_SIZE_MB=25

# Admin inicial (usado apenas no seed — troque a senha!)
ADMIN_EMAIL=admin@pertenser.com.br
ADMIN_PASSWORD=admin123
